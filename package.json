        gananciaActual: i.gananciaActual,
        roi: i.roi,
        progreso: i.progreso
      }))
    };

    let csvContent = "data:text/csv;charset=utf-8,";
    
    csvContent += "GRIZALUM - REPORTE FINANCIERO\n";
    csvContent += `Fecha: ${datosExcel.fecha}\n\n`;
    
    csvContent += "RESUMEN EJECUTIVO\n";
    csvContent += "Concepto,Monto\n";
    csvContent += `Por Cobrar,S/ ${datosExcel.resumen.porCobrar.toLocaleString()}\n`;
    csvContent += `Por Pagar,S/ ${datosExcel.resumen.porPagar.toLocaleString()}\n`;
    csvContent += `Balance Neto,S/ ${datosExcel.resumen.balanceNeto.toLocaleString()}\n`;
    csvContent += `Cobertura,${datosExcel.resumen.cobertura}%\n\n`;
    
    csvContent += "CARTERA DE CLIENTES\n";
    csvContent += "Nombre,Capital,Saldo Pendiente,Cuota Mensual,Estado,Pagos Realizados\n";
    datosExcel.clientes.forEach(cliente => {
      csvContent += `${cliente.nombre},S/ ${cliente.capital.toLocaleString()},S/ ${cliente.saldoPendiente.toLocaleString()},S/ ${cliente.cuotaMensual.toLocaleString()},${cliente.estado},${cliente.pagosRealizados}\n`;
    });
    
    csvContent += "\n";
    
    csvContent += "GESTION DE DEUDAS\n";
    csvContent += "Acreedor,Capital,Saldo Pendiente,Cuota Mensual,Tipo,Estado\n";
    datosExcel.deudas.forEach(deuda => {
      csvContent += `${deuda.acreedor},S/ ${deuda.capital.toLocaleString()},S/ ${deuda.saldoPendiente.toLocaleString()},S/ ${deuda.cuotaMensual.toLocaleString()},${deuda.tipo},${deuda.estado}\n`;
    });
    
    csvContent += "\n";
    
    csvContent += "PORTFOLIO DE INVERSIONES\n";
    csvContent += "Nombre,Tipo,Inversion,Ganancia Esperada,Ganancia Actual,ROI,Progreso\n";
    datosExcel.inversiones.forEach(inversion => {
      csvContent += `${inversion.nombre},${inversion.tipo},S/ ${inversion.inversion.toLocaleString()},S/ ${inversion.gananciaEsperada.toLocaleString()},S/ ${inversion.gananciaActual.toLocaleString()},${inversion.roi}%,${inversion.progreso}%\n`;
    });

    const encodedUri = encodeURI(csvContent);
    const link = document.createElement("a");
    link.setAttribute("href", encodedUri);
    link.setAttribute("download", `GRIZALUM_Reporte_Financiero_${new Date().toISOString().split('T')[0]}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    
    alert('📊 Reporte Excel descargado exitosamente');
  };

